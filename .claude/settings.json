  "includeCoAuthoredBy" : false,
  "inputNeededNotifEnabled" : true,
  "language" : "Japanese",
  "model" : "opus",
  "permissions" : {
    "allow" : [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "Task",
      "TodoWrite",
      "NotebookEdit"
    ],
    "ask" : [

    ],
    "defaultMode" : "auto",
    "deny" : [
      "Bash(sudo rm -rf *)",
      "Bash(sudo mkfs *)",
      "Bash(sudo dd *)",
      "Bash(rm -rf \/)",
      "Bash(chmod 777 *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~\/.ssh\/**)",
      "Read(~\/.aws\/**)",
      "Read(~\/.kube\/config)",
      "Read(~\/.docker\/config.json)",
      "Read(~\/.config\/gcloud\/**)",
      "Read(~\/.azure\/**)"
